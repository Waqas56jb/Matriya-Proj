# Copy to .env — fill with real values. Never commit .env (gitignored).
# This file must contain ONLY placeholders (no passwords or API keys).

POSTGRES_URL=postgresql://USER:PASSWORD@HOST:6543/postgres
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_supabase_service_role_or_secret_key
JWT_SECRET=use_a_long_random_string
OPENAI_API_KEY=sk-your-openai-key
LLM_PROVIDER=openai
COLLECTION_NAME=rag_documents
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MANAGEMENT_BACK_URL=https://your-management-app.vercel.app
MATRIYA_MANAGEMENT_API_URL=https://your-management-app.vercel.app
API_HOST=0.0.0.0
API_PORT=8000
MAX_FILE_SIZE=52428800
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Twilio — WhatsApp webhook (Task H)
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WEBHOOK_PUBLIC_URL=https://matriya-back.vercel.app/api/webhook/whatsapp
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+972000000000
TWILIO_WHATSAPP_REPLY=1
# TWILIO_REPLY_TEXT_TEMPLATE=Got it: {task}

# Optional: only these senders (comma-separated Twilio From values)
# WHATSAPP_ALLOWED_FROM=whatsapp:+972000000000

# Optional: Claude Code after each WhatsApp message
# CLAUDE_CODE_WEBHOOK_ENABLED=1
# CLAUDE_CODE_ARGV_JSON=["npx","-y","your-cli-or-wrapper","--task"]
