# Copy to .env — fill with real values. Never commit .env (gitignored).
# This file must contain ONLY placeholders (no passwords or API keys).

POSTGRES_URL=postgresql://USER:PASSWORD@HOST:6543/postgres
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_supabase_service_role_or_secret_key
JWT_SECRET=use_a_long_random_string
OPENAI_API_KEY=sk-your-openai-key
LLM_PROVIDER=openai
COLLECTION_NAME=rag_documents
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MANAGEMENT_BACK_URL=https://your-management-app.vercel.app
MATRIYA_MANAGEMENT_API_URL=https://your-management-app.vercel.app
API_HOST=0.0.0.0
API_PORT=8000
MAX_FILE_SIZE=52428800
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# ─── Twilio Gateway (Milestones 1 & 2) ───────────────────────────────────────
# Account credentials (Twilio Console → Account → API keys & tokens)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Signature validation — must exactly match the URL configured in Twilio Console
# Set to: https://your-api.vercel.app/api/whatsapp/inbound
TWILIO_WEBHOOK_PUBLIC_URL=https://your-api.vercel.app/api/whatsapp/inbound

# Your Twilio WhatsApp sender number (without whatsapp: prefix)
TWILIO_WHATSAPP_NUMBER=+14155238886
# Same number with prefix (used by legacy webhook route)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Set to 1 to enable auto-replies
TWILIO_WHATSAPP_REPLY=1
# Optional custom reply text; {task} is replaced with the inbound message
# TWILIO_REPLY_TEXT_TEMPLATE=Got it: {task}

# Optional: only accept messages from these numbers (comma-separated)
# WHATSAPP_ALLOWED_FROM=whatsapp:+972000000000

# ─── WhatsApp Pipeline (whatsappPipeline.js) ─────────────────────────────────
# David's WhatsApp number — receives GO/WAIT/NO-GO results automatically
DAVID_WHATSAPP=whatsapp:+972544568078

# ─── Claude Code automation (optional) ───────────────────────────────────────
# CLAUDE_CODE_WEBHOOK_ENABLED=1
# CLAUDE_CODE_ARGV_JSON=["npx","-y","your-cli-or-wrapper","--task"]
