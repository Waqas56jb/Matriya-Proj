{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 300,
      "memory": 2048
    }
  },
  "crons": [
    {
      "path": "/api/whatsapp/process-pending",
      "schedule": "* * * * *"
    }
  ]
}
